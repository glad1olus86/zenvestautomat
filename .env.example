# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Groq (Whisper STT)
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://zenvest:changeme@postgres:5432/zenvest

# Redis
REDIS_URL=redis://redis:6379

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service-account.json
GOOGLE_SHEET_ID=your_sheet_id_here

# Google Drive (false = отключить загрузку)
GOOGLE_DRIVE_ENABLED=true
GOOGLE_DRIVE_FOLDER_ID=your_shared_drive_folder_id_here

# Группа руководства (алерты о пропущенных REPORT, необязательно)
MANAGEMENT_GROUP_ID=
MANAGEMENT_TOPIC_ID=

# Приложение
PORT=3000
NODE_ENV=production
DAILY_REPORT_TIME=20:00
REPORT_REMINDER_TIME=18:00
TIMEZONE=Europe/Prague
